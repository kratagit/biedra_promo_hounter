{
  "name": "biedronka-promo-hunter",
  "version": "1.0.0",
  "description": "Wyszukiwarka promocji w gazetkach Biedronki",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.biedronka.promohunter",
    "productName": "Biedronka Promo Hunter",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "python_dist/",
        "to": "python_dist",
        "filter": ["**/*"]
      },
      {
        "from": "tesseract_dist/",
        "to": "tesseract_dist",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
